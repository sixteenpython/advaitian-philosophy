# vriddhi_templates.py
def simple_explain(retrieved_rows):
    # retrieved_rows: list of {"score":..., "row":{...}}
    lines = []
    for r in retrieved_rows:
        row = r["row"]
        ticker = row.get("Ticker", row.get("ticker", "Unknown"))
        name = row.get("Name", "")
        sector = row.get("Sector", "")
        cagr = row.get("Average CAGR", row.get("Average CAGR (%)", None))
        momentum = row.get("Momentum Score", None)
        parts = [f"**{ticker}**"]
        if name: parts.append(name)
        if sector: parts.append(f"({sector})")
        if cagr is not None and str(cagr) != "nan":
            parts.append(f"Avg CAGR: {cagr}")
        if momentum is not None and str(momentum) != "nan":
            parts.append(f"Momentum: {momentum}")
        lines.append(" • ".join(parts))
    return "\n\n".join(lines)
