"use client";
import { useState } from "react";
import axios from "axios";

export default function Home() {
  const [monthly, setMonthly] = useState(25000);
  const [months, setMonths] = useState(60);
  const [cagr, setCagr] = useState(0.18);
  const [result, setResult] = useState<any>(null);
  const [loading, setLoading] = useState(false);

  const submit = async () => {
    setLoading(true);
    try {
      const { data } = await axios.post(
        process.env.NEXT_PUBLIC_API_BASE + "/optimize",
        { monthly_investment: monthly, horizon_months: months, target_cagr: cagr }
      );
      setResult(data);
    } finally { setLoading(false); }
  };

  return (
    <main style={{ maxWidth: 720, margin: "2rem auto" }}>
      <h1>Vriddhi Portfolio Optimizer</h1>
      <label>Monthly Investment</label>
      <input type="number" value={monthly} onChange={e=>setMonthly(+e.target.value)} />
      <label>Horizon (months)</label>
      <input type="number" value={months} onChange={e=>setMonths(+e.target.value)} />
      <label>Target CAGR</label>
      <input type="number" step="0.01" value={cagr} onChange={e=>setCagr(+e.target.value)} />

      <button onClick={submit} disabled={loading}>{loading ? "Optimizing..." : "Optimize"}</button>

      {result && (
        <>
          <h2>Summary</h2>
          <pre>{JSON.stringify(result.summary, null, 2)}</pre>
          <h2>Allocations</h2>
          <ul>
            {result.allocations.map((a:any)=>(
              <li key={a.ticker}>{a.ticker}: {(a.weight*100).toFixed(1)}%</li>
            ))}
          </ul>
        </>
      )}
    </main>
  );
