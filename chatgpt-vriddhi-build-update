5) GitLab CI/CD (+ Cloud Run deploy example)
Create service account on GCP with permissions: Cloud Run Admin, Artifact Registry Writer, Service Account User. Save its JSON as a masked CI variable GCP_SA_KEY. Set variables: GCP_PROJECT_ID, GCP_REGION (e.g., asia-south1), BACKEND_SERVICE, FRONTEND_SERVICE.

infra/.gitlab-ci.yml

stages: [build, deploy]

variables:
  DOCKER_DRIVER: overlay2
  GCP_PROJECT_ID: $GCP_PROJECT_ID
  GCP_REGION: $GCP_REGION

.default: &gcloud
  image: gcr.io/google.com/cloudsdktool/cloud-sdk:slim
  before_script:
    - echo "$GCP_SA_KEY" > ${CI_PROJECT_DIR}/gcp-key.json
    - gcloud auth activate-service-account --key-file gcp-key.json
    - gcloud config set project $GCP_PROJECT_ID
    - gcloud auth configure-docker ${GCP_REGION}-docker.pkg.dev -q

build-backend:
  stage: build
  image: docker:24
  services: [docker:24-dind]
  script:
    - docker build -t ${CI_REGISTRY_IMAGE}/backend:${CI_COMMIT_SHORT_SHA} -f backend/Dockerfile .
    - docker push ${CI_REGISTRY_IMAGE}/backend:${CI_COMMIT_SHORT_SHA}
  only: [main]

build-frontend:
  stage: build
  image: docker:24
  services: [docker:24-dind]
  script:
    - docker build --build-arg NEXT_PUBLIC_API_BASE=${PUBLIC_API_BASE} -t ${CI_REGISTRY_IMAGE}/frontend:${CI_COMMIT_SHORT_SHA} -f frontend/Dockerfile .
    - docker push ${CI_REGISTRY_IMAGE}/frontend:${CI_COMMIT_SHORT_SHA}
  only: [main]

deploy-backend:
  stage: deploy
  <<: *gcloud
  script:
    - gcloud run deploy ${BACKEND_SERVICE}
        --image ${CI_REGISTRY_IMAGE}/backend:${CI_COMMIT_SHORT_SHA}
        --region ${GCP_REGION} --platform managed
        --allow-unauthenticated --port 8000
        --set-env-vars DATA_PATH=/app/data/stocks.csv
  only: [main]

deploy-frontend:
  stage: deploy
  <<: *gcloud
  script:
    - gcloud run deploy ${FRONTEND_SERVICE}
        --image ${CI_REGISTRY_IMAGE}/frontend:${CI_COMMIT_SHORT_SHA}
        --region ${GCP_REGION} --platform managed
        --allow-unauthenticated --port 3000
        --set-env-vars NEXT_PUBLIC_API_BASE=${PUBLIC_API_BASE}
  only: [main]
