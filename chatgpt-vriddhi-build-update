import pandas as pd
from sentence_transformers import SentenceTransformer
from chromadb import Client
from chromadb.config import Settings
from transformers import pipeline

def init_vriddhi_local(csv_path="grand_table.csv"):
    df = pd.read_csv(csv_path)

    # Convert rows into text summaries
    docs = [
        f"{row['Stock']} | Sector: {row['Sector']} | PE: {row['PE']} | PB: {row['PB']} | CAGR: {row['Average CAGR']} | Momentum: {row['Momentum Score']}"
        for _, row in df.iterrows()
    ]

    # Initialize Chroma (local mode)
    client = Client(Settings(anonymized_telemetry=False))
    collection = client.create_collection("vriddhi_stocks", get_or_create=True)

    # Create embeddings
    model = SentenceTransformer("all-MiniLM-L6-v2")
    embeddings = model.encode(docs).tolist()

    # Store embeddings
    for i, text in enumerate(docs):
        collection.add(documents=[text], embeddings=[embeddings[i]], metadatas=[df.iloc[i].to_dict()])

    # Load a small open-source LLM
    llm = pipeline("text-generation", model="facebook/blenderbot-400M-distill")

    return collection, llm

def ask_vriddhi(collection, llm, query, top_k=3):
    results = collection.query(query_texts=[query], n_results=top_k)
    context = " ".join(results['documents'][0])
    prompt = f"Based on the following data: {context}. Answer this question: {query}"
    response = llm(prompt, max_length=200, num_return_sequences=1)
    return response[0]['generated_text']
