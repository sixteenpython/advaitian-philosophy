# vriddhi_retriever.py
import pandas as pd
from sentence_transformers import SentenceTransformer
import numpy as np
from sklearn.metrics.pairwise import cosine_similarity

def ensure_embeddings(csv_path="grand_table.csv"):
    df = pd.read_csv(csv_path)
    docs = df.apply(lambda r: f"{r.get('Ticker','')} {r.get('Sector','')} {r.get('Average CAGR','')} {r.to_dict()}", axis=1).tolist()
    model = SentenceTransformer("all-MiniLM-L6-v2")
    embeddings = model.encode(docs, show_progress_bar=False)
    return df, embeddings, docs

def retrieve(query, df, embeddings, docs, top_k=3):
    model = SentenceTransformer("all-MiniLM-L6-v2")
    q_emb = model.encode([query], show_progress_bar=False)
    sims = cosine_similarity(q_emb, embeddings)[0]
    top_idx = np.argsort(sims)[::-1][:top_k]
    results = []
    for idx in top_idx:
        results.append({
            "row": df.iloc[idx].to_dict(),
            "score": round(float(sims[idx]), 3)
        })
    return results
