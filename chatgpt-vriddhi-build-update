# Run locally: computes 5-year CAGR for Nifty 50 tickers
# Requires: pip install yfinance pandas numpy

import yfinance as yf
import pandas as pd
import numpy as np
from datetime import datetime, timedelta

# 1) Paste your Nifty 50 tickers here (Yahoo format usually 'TCS.NS', 'RELIANCE.NS', etc.)
tickers = [
  "RELIANCE.NS","TCS.NS","INFY.NS","HDFCBANK.NS","ICICIBANK.NS",
  # ... add full Nifty50 list ...
]

end = datetime.utcnow().date()
start = end - timedelta(days=365*5)  # approx 5 years
results = []
for t in tickers:
    try:
        df = yf.download(t, start=start.strftime("%Y-%m-%d"), end=end.strftime("%Y-%m-%d"), progress=False, auto_adjust=True)
        if df.empty: 
            continue
        start_price = df['Close'].iloc[0]
        end_price = df['Close'].iloc[-1]
        years = (df.index[-1] - df.index[0]).days / 365.25
        cagr = (end_price / start_price) ** (1/years) - 1
        results.append((t, cagr, start_price, end_price))
    except Exception as e:
        print("err", t, e)

res_df = pd.DataFrame(results, columns=["ticker","cagr","start","end"]).sort_values("cagr", ascending=False)
print(res_df.head(10).to_string(index=False))
