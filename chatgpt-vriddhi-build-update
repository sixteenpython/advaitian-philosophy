from fastapi import FastAPI, HTTPException
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel, Field
from datetime import date
from vriddhi_core.data_access import CsvKnowledgeAsset
from vriddhi_core.optimizer import optimize_portfolio, OptimizeParams

app = FastAPI(title="Vriddhi IL", version="0.1.0")

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],  # tighten later
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

KA = CsvKnowledgeAsset("data/stocks.csv")
KA.load(force=True)

class OptimizeReq(BaseModel):
    monthly_investment: float = Field(gt=0)
    horizon_months: int = Field(gt=0)
    target_cagr: float = Field(gt=0)
    risk_tolerance: str | None = None
    max_stock_weight: float | None = None
    sector_caps: dict[str, float] | None = None
    asof_date: date | None = None
    universe_tag: str | None = None
    explain: bool = True

@app.get("/healthz")
def healthz():
    meta = KA.metadata()
    return {"status":"ok","data_version":meta}

@app.get("/universe")
def universe():
    df = KA.get_universe()
    return {"columns": list(df.columns), "rows": len(df)}

@app.post("/optimize")
def optimize(req: OptimizeReq):
    df = KA.get_universe()
    try:
        params = OptimizeParams(
            monthly_investment=req.monthly_investment,
            horizon_months=req.horizon_months,
            target_cagr=req.target_cagr,
            risk_tolerance=req.risk_tolerance,
            max_stock_weight=req.max_stock_weight,
            sector_caps=req.sector_caps,
        )
        result = optimize_portfolio(df, params)
        result["data_version"] = KA.metadata()
        return result
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))
