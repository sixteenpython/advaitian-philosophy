# vriddhi_local_llm.py
from transformers import pipeline
from vriddhi_retriever import ensure_embeddings, retrieve

# initialize a small instruction model (text2text)
def init_llm_and_retriever(csv_path="grand_table.csv"):
    df, embeddings, docs = ensure_embeddings(csv_path)
    # small instruction model; change if you prefer others
    llm = pipeline("text2text-generation", model="google/flan-t5-small", device=-1)
    return df, embeddings, docs, llm

def answer_with_llm(llm, query, top_docs):
    # Build a concise prompt combining top_docs
    evidence = "\n".join([f"{i+1}. {d['row'].get('Ticker','')}: {d['row'].get('Name','')} — Avg CAGR {d['row'].get('Average CAGR','')}" for i,d in enumerate(top_docs)])
    prompt = f"You are Vriddhi assistant. Using ONLY the evidence below, answer the user query concisely.\n\nEvidence:\n{evidence}\n\nQuestion: {query}\n\nAnswer in bullets, give suggested weights out of 100 if relevant."
    out = llm(prompt, max_length=200)[0]['generated_text']
    return out
