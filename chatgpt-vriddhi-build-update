AUTH0_CLIENT_ID = st.secrets["AUTH0_CLIENT_ID"]
# Use the redirect URI for the environment (local or deployed)
AUTH0_REDIRECT_URI = st.secrets["AUTH0_REDIRECT_URI"]  # e.g., http://localhost:8501/ or deployed URL
AUTH0_AUTHORIZE_URL = f"https://{AUTH0_DOMAIN}/authorize"
AUTH0_TOKEN_URL = f"https://{AUTH0_DOMAIN}/oauth/token"
AUTH0_USERINFO_URL = f"https://{AUTH0_DOMAIN}/userinfo"
AUTH0_LOGOUT_URL = f"https://{AUTH0_DOMAIN}/v2/logout"

# Helpers: PKCE code verifier & challenge
def generate_code_verifier() -> str:
    # high-entropy random string
    return base64.urlsafe_b64encode(secrets.token_bytes(40)).rstrip(b"=").decode("utf-8")

def generate_code_challenge(verifier: str) -> str:
    digest = hashlib.sha256(verifier.encode("utf-8")).digest()
    return base64.urlsafe_b64encode(digest).rstrip(b"=").decode("utf-8")

def build_auth_url():
    state = uuid.uuid4().hex
    code_verifier = generate_code_verifier()
    code_challenge = generate_code_challenge(code_verifier)

    # store code_verifier keyed by state in session so we can exchange later
    st.session_state.setdefault("_auth_codes", {})[state] = {
        "code_verifier": code_verifier,
        "created_at": time.time()
    }

    params = {
        "response_type": "code",
        "client_id": AUTH0_CLIENT_ID,
        "redirect_uri": AUTH0_REDIRECT_URI,
        "scope": "openid profile email",
        "state": state,
        "code_challenge": code_challenge,
        "code_challenge_method": "S256",
        # optionally add 'audience' if you have an API configured
    }
    return AUTH0_AUTHORIZE_URL + "?" + urllib.parse.urlencode(params)

def exchange_code_for_tokens(code: str, code_verifier: str):
    data = {
        "grant_type": "authorization_code",
        "client_id": AUTH0_CLIENT_ID,
        "code_verifier": code_verifier,
        "code": code,
        "redirect_uri": AUTH0_REDIRECT_URI
    }
    headers = {"Content-Type": "application/x-www-form-urlencoded"}
    resp = requests.post(AUTH0_TOKEN_URL, data=data, headers=headers, timeout=10)
    resp.raise_for_status()
    return resp.json()  # contains access_token, id_token, expires_in, token_type

def fetch_userinfo(access_token: str):
    headers = {"Authorization": f"Bearer {access_token}"}
    resp = requests.get(AUTH0_USERINFO_URL, headers=headers, timeout=10)
    resp.raise_for_status()
    return resp.json()

# Check for OAuth response (Auth0 redirects here with ?code=...&state=...)
query_params = st.experimental_get_query_params()
if "code" in query_params and "state" in query_params:
    code = query_params["code"][0]
    state = query_params["state"][0]
    auth_map = st.session_state.setdefault("_auth_codes", {})
    entry = auth_map.get(state)
    if entry:
        try:
            tokens = exchange_code_for_tokens(code, entry["code_verifier"])
            access_token = tokens.get("access_token")
            id_token = tokens.get("id_token")
            # Confirm token by calling userinfo endpoint
            profile = fetch_userinfo(access_token)
            # Persist user info in session
            st.session_state["user"] = {
                "profile": profile,
                "access_token": access_token,
                "id_token": id_token,
                "expires_at": time.time() + tokens.get("expires_in", 3600)
            }
            # Clear the query params in URL (nice to avoid showing code)
            st.experimental_set_query_params()
            st.experimental_rerun()
        except Exception as e:
            st.error(f"Authentication failed: {e}")
    else:
        st.warning("Missing auth state. Please try logging in again.")

# Quick function to render Login / Logout UI
def login_button():
    auth_url = build_auth_url()
    # Provide a prominent link/button for login. Clicking opens Auth0 hosted login.
    st.markdown(f'<a href="{auth_url}" target="_self"><button style="padding:10px 18px; font-size:16px;">🔐 Login with Auth0 (Google / Email)</button></a>', unsafe_allow_html=True)

def logout_button():
    # Remove local session and redirect to Auth0 logout to clear session there as well
    st.session_state.pop("user", None)
    # returnTo must be an allowed logout URL in Auth0 settings
    return_to = AUTH0_REDIRECT_URI
    logout_url = AUTH0_LOGOUT_URL + "?" + urllib.parse.urlencode({"client_id": AUTH0_CLIENT_ID, "returnTo": return_to})
    st.markdown(f'<a href="{logout_url}" target="_self"><button style="padding:8px 14px;">Logout</button></a>', unsafe_allow_html=True)

# Main gating logic: show login or the protected app UI
if "user" not in st.session_state:
    st.sidebar.write("## Sign in")
    login_button()
    st.sidebar.write("You will be redirected to a secure Auth0 sign-in page.")
    # Stop execution of app so the rest is protected; you can remove this `st.stop()` if you want public parts below.
    st.stop()

# If we reach here, user is logged in
user = st.session_state["user"]["profile"]
st.sidebar.success(f"Signed in as {user.get('name') or user.get('email')}")
if st.sidebar.button("Logout"):
    logout_button()
# --- END AUTH0 SNIPPET ---
Notes on the code

We use PKCE (code verifier + code challenge) so no client secret is required in the client code. This is secure for public apps.

We call /oauth/token to exchange the code for access_token, then we call /userinfo to fetch the user profile (email, name, picture). This avoids having to manually verify the ID token signature in your app (Auth0 validates it server-side).

We store the logged-in user profile in st.session_state["user"]. Use this to gate the portfolio creation UI.

We use st.experimental_set_query_params() to clear ?code=... from the URL after successful login.

