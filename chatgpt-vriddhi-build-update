# vriddhi_retriever.py
import os
import json
import numpy as np
import pandas as pd
from sentence_transformers import SentenceTransformer
from sklearn.metrics.pairwise import cosine_similarity

EMB_FILE = "vriddhi_embeddings.npy"
META_FILE = "vriddhi_metadata.json"
MODEL_NAME = "all-MiniLM-L6-v2"  # small & fast

def build_docs_from_row(row):
    # create a concise text representation of a row for semantic search
    parts = []
    parts.append(f"{row.get('Ticker','')} {row.get('Name','')}")
    if 'Sector' in row: parts.append(f"Sector: {row['Sector']}")
    # add the important numeric fields if available (PE/PB/CAGR/Momentum)
    for k in ['PE','PB','Average CAGR','Momentum Score','12M CAGR','60M CAGR']:
        if k in row and not pd.isna(row[k]):
            parts.append(f"{k}: {row[k]}")
    return " | ".join(parts)

def ensure_embeddings(csv_path="grand_table.csv"):
    # returns (df, embeddings, docs)
    df = pd.read_csv(csv_path)
    if os.path.exists(EMB_FILE) and os.path.exists(META_FILE):
        try:
            embeddings = np.load(EMB_FILE)
            with open(META_FILE, "r", encoding="utf-8") as f:
                meta = json.load(f)
            # sanity check
            if len(meta) == len(df) and embeddings.shape[0] == len(df):
                docs = [m['doc'] for m in meta]
                return df, embeddings, docs
        except Exception:
            pass

    # compute
    model = SentenceTransformer(MODEL_NAME)
    docs = [build_docs_from_row(row) for _, row in df.iterrows()]
    embeddings = model.encode(docs, show_progress_bar=True)
    # persist
    np.save(EMB_FILE, embeddings)
    meta = [{"doc": d, "row_index": int(i)} for i, d in enumerate(docs)]
    with open(META_FILE, "w", encoding="utf-8") as f:
        json.dump(meta, f)
    return df, embeddings, docs

def retrieve(query, df, embeddings, docs, top_k=5):
    model = SentenceTransformer(MODEL_NAME)
    q_emb = model.encode([query])
    sims = cosine_similarity(q_emb, embeddings)[0]  # shape (n,)
    idx = np.argsort(-sims)[:top_k]
    results = []
    for i in idx:
        row = df.iloc[i].to_dict()
        results.append({"score": float(sims[i]), "row": row})
    return results
Notes:

The first run will compute & save vriddhi_embeddings.npy and vriddhi_metadata.json (fast).

all-MiniLM-L6-v2 is tiny and runs on CPU quickly.

