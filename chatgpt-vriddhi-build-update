import pandas as pd
from pathlib import Path
from datetime import datetime

class CsvKnowledgeAsset:
    def __init__(self, path: str = "data/stocks.csv"):
        self.path = Path(path)
        self._df = None
        self._loaded_at = None

    def load(self, force: bool = False):
        if self._df is None or force:
            self._df = pd.read_csv(self.path)
            self._loaded_at = datetime.utcnow()
        return self._df

    def get_universe(self):
        return self.load()

    def metadata(self):
        return {"rows": len(self._df or []), "loaded_at": self._loaded_at, "path": str(self.path)}
