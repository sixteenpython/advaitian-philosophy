import pandas as pd
from langchain.embeddings.openai import OpenAIEmbeddings
from langchain.vectorstores import Chroma
from langchain.chat_models import ChatOpenAI
from langchain.chains import ConversationalRetrievalChain

def init_vriddhi_rag(csv_path="grand_table.csv"):
    df = pd.read_csv(csv_path)

    # Convert each stock row into a descriptive text chunk
    texts = [
        f"{row['Stock']} | Sector: {row['Sector']} | PE: {row['PE']} | PB: {row['PB']} | Avg CAGR: {row['Average CAGR']} | Momentum: {row['Momentum Score']}"
        for _, row in df.iterrows()
    ]

    # Embed + store in Chroma (local in-memory vector DB)
    embeddings = OpenAIEmbeddings()
    vectordb = Chroma.from_texts(texts, embeddings, metadatas=df.to_dict('records'))

    # Create a conversational retrieval chain
    llm = ChatOpenAI(model_name="gpt-4o-mini", temperature=0)
    qa_chain = ConversationalRetrievalChain.from_llm(
        llm=llm, retriever=vectordb.as_retriever(search_kwargs={"k": 5})
    )
    return qa_chain
