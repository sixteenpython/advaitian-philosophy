from fastapi import FastAPI, HTTPException
from pydantic import BaseModel
from datetime import date
from vriddhi_core import optimizer, data_access, explain

app = FastAPI()

class OptimizeReq(BaseModel):
    monthly_investment: float
    horizon_months: int
    target_cagr: float
    risk_tolerance: str | None = None
    max_stock_weight: float | None = None
    sector_caps: dict[str, float] | None = None
    asof_date: date
    universe_tag: str = "core20"
    explain: bool = True

@app.post("/optimize")
def optimize(req: OptimizeReq):
    ka = data_access.PostgresKA()   # read-only
    U = ka.get_universe(req.asof_date, req.universe_tag)
    F = ka.get_forecasts(req.asof_date, req.universe_tag)
    C = ka.get_constraints(req.asof_date, scope="retail")
    result = optimizer.solve(U, F, C, params=req.model_dump())
    run_id = data_access.persist_run(result)
    if req.explain:
        result["allocations"] = explain.attach_rationales(result["allocations"], U, F)
    result["run_id"] = run_id
    return result
