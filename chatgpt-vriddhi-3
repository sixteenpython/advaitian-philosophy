    sharpe_score = max(0, 10 - (row['Sharpe'] - 1)**2 * 10)

    # VaR Score: Lower is better
    var_score = max(0, 10 - row['VaR'] * 20)

    total_score = (peg_score + pb_score + pe_score + sharpe_score + var_score) / 5
    return round(total_score, 2)

