import yfinance as yf
import numpy as np
import torch
import torch.nn as nn
from sklearn.preprocessing import MinMaxScaler

class StockPricePredictor(nn.Module):
    def __init__(self, input_size, hidden_size, output_size):
        super(StockPricePredictor, self).__init__()
        self.lstm = nn.LSTM(input_size, hidden_size, batch_first=True)
        self.fc = nn.Linear(hidden_size, output_size)

    def forward(self, x):
        out, _ = self.lstm(x)
        return self.fc(out[:, -1, :])

def fetch_data(ticker):
    df = yf.download(ticker, start='2015-01-01', end='2025-01-01')
    return df[['Close']]

def run_predictions(tickers):
    for ticker in tickers:
        df = fetch_data(ticker)
        scaler = MinMaxScaler()
        data = scaler.fit_transform(df)

        def create_sequences(data, step=30):
            x, y = [], []
            for i in range(len(data) - step):
                x.append(data[i:i+step])
                y.append(data[i+step])
            return np.array(x), np.array(y)

        x, y = create_sequences(data)
        x_tensor = torch.tensor(x, dtype=torch.float32)
        y_tensor = torch.tensor(y, dtype=torch.float32)

        model = StockPricePredictor(1, 64, 1)
        optimizer = torch.optim.Adam(model.parameters(), lr=0.001)
        loss_fn = nn.MSELoss()

        for _ in range(100):
            model.train()
            output = model(x_tensor)
            loss = loss_fn(output.squeeze(), y_tensor.squeeze())
            optimizer.zero_grad()
            loss.backward()
            optimizer.step()

        print(f"Model trained for {ticker}.")
