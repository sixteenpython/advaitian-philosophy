Calculates HHS and adjusts predictions accordingly.

# vriddhi_pro.py
import numpy as np

class VriddhiPro:
    def __init__(self, db, predictor):
        self.db = db
        self.predictor = predictor

    def compute_hhs(self, stock_info):
        # Normalize using ideal values
        peg_score = max(0, 1 - (stock_info['PEG'] / 2))  # Ideal PEG = 1
        pe_score = max(0, 1 - (stock_info['P/E'] / 25))  # Ideal P/E = 20-25
        pb_score = max(0, 1 - (stock_info['P/B'] / 3))   # Ideal P/B < 3
        sharpe_score = max(0, 1 - abs(stock_info['SharpeRatio'] - 1))
        var_score = 1 - (stock_info['VaR'] / 0.1) if stock_info['VaR'] < 0.1 else 0

        weights = {'peg': 0.25, 'pe': 0.2, 'pb': 0.2, 'sharpe': 0.25, 'var': 0.1}
        hhs = (
            weights['peg'] * peg_score +
            weights['pe'] * pe_score +
            weights['pb'] * pb_score +
            weights['sharpe'] * sharpe_score +
            weights['var'] * var_score
        )
        return round(hhs, 2)

    def adjusted_forecast(self, predictions, hhs):
        adjustment_factor = 0.5 + hhs  # scale between 0.5x to 1.5x
        return [round(p * adjustment_factor, 2) for p in predictions]

    def get_forecast_report(self, tickers, hist_data_dict):
        report = {}
        for ticker in tickers:
            info = self.db.get_stock_info(ticker)
            hhs = self.compute_hhs(info)
            raw_pred = self.predictor.predict_future_prices(ticker, hist_data_dict[ticker])
            adjusted = self.adjusted_forecast(raw_pred, hhs)
            report[ticker] = {
                'HHS': hhs,
                'RawPrediction': raw_pred[:7],  # 3m, 6m...60m
                'HHS_Adjusted': adjusted[:7]
            }
        return report
