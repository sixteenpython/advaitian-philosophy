import requests
import pandas as pd
from bs4 import BeautifulSoup
import yfinance as yf
import sqlite3
import numpy as np
import time
import os

# Create output folder
os.makedirs("data", exist_ok=True)

# Risk-free rate (annual): ~6%
RISK_FREE_RATE_DAILY = 0.06 / 252

# Your stock list
tickers = [
    "TCS.NS", "INFY.NS", "HDFCBANK.NS", "RELIANCE.NS", "ITC.NS",
    "ULTRACEMCO.NS", "BAJFINANCE.NS", "LT.NS", "SUNPHARMA.NS", "AXISBANK.NS"
]

# Function to fetch P/E, P/B and EPS growth from Screener.in
def fetch_screener_ratios(ticker):
    try:
        url = f'https://www.screener.in/company/{ticker.replace(".NS", "")}/'
        headers = {'User-Agent': 'Mozilla/5.0'}
        r = requests.get(url, headers=headers)
        soup = BeautifulSoup(r.text, 'html.parser')

        pe = float(soup.find(text='P/E').find_next().text.replace(",", ""))
        pb = float(soup.find(text='P/B').find_next().text.replace(",", ""))
        growth_tag = soup.find(text="Compounded Sales Growth")
        eps_growth = None
        if growth_tag:
            row = growth_tag.find_parent("table").find_all("tr")[1]
            growth_text = row.find_all("td")[1].text.strip().replace("%", "")
            eps_growth = float(growth_text) if growth_text else None

        return pe, pb, eps_growth
    except Exception as e:
        print(f"[Screener Error] {ticker}: {e}")
        return None, None, None

# Function to calculate Sharpe Ratio using 1-yr price history
def calculate_sharpe(ticker):
    try:
        df = yf.download(ticker, period="1y", interval="1d")['Close'].dropna()
        returns = df.pct_change().dropna()
        avg_return = returns.mean()
        std_dev = returns.std()
        sharpe = (avg_return - RISK_FREE_RATE_DAILY) / std_dev
        return round(float(sharpe), 2)
    except Exception as e:
        print(f"[Sharpe Error] {ticker}: {e}")
        return None

# Loop through all tickers
records = []

for ticker in tickers:
    print(f"Processing {ticker}...")
    pe, pb, eps_growth = fetch_screener_ratios(ticker)
    sharpe = calculate_sharpe(ticker)
    
    peg = None
    if pe is not None and eps_growth and eps_growth != 0:
        peg = round(pe / eps_growth, 2)
    
    records.append({
        "ticker": ticker,
        "pe_ratio": pe,
        "pb_ratio": pb,
        "peg_ratio": peg,
        "sharpe_ratio": sharpe
    })
    
    time.sleep(4)  # be polite to Screener.in

# Create DataFrame
df = pd.DataFrame(records)
print(df)

# Save to SQLite
conn = sqlite3.connect("data/stock_fundamentals.db")
df.to_sql("fundamentals", conn, if_exists="replace", index=False)
conn.close()

print("✅ Fundamentals updated in database.")

