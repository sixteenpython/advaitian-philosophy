import yfinance as yf
import sqlite3

def fetch_actual_price(ticker):
    try:
        df = yf.download(ticker, period="1d", interval="1d")
        return float(df['Close'].iloc[0])
    except:
        return None

def run_backtest():
    conn = sqlite3.connect("stock_fundamentals.db")
    cursor = conn.cursor()
    cursor.execute("SELECT ticker, adjusted_price_3m FROM fundamentals")
    for row in cursor.fetchall():
        ticker, predicted = row
        actual = fetch_actual_price(ticker)
        if actual and predicted:
            abs_err = round(abs(actual - predicted), 2)
            pct_err = round((actual - predicted) / predicted, 4)
            cursor.execute("ALTER TABLE fundamentals ADD COLUMN IF NOT EXISTS abs_error REAL")
            cursor.execute("ALTER TABLE fundamentals ADD COLUMN IF NOT EXISTS pct_error REAL")
            cursor.execute("UPDATE fundamentals SET abs_error = ?, pct_error = ? WHERE ticker = ?",
                           (abs_err, pct_err, ticker))
    conn.commit()
    conn.close()
