# Cell 1: Imports
import yfinance as yf
import numpy as np
import torch
import torch.nn as nn
from sklearn.preprocessing import MinMaxScaler
import time
# Cell 2: Define model class

class StockLSTM(nn.Module):
    def __init__(self, input_size=1, hidden_size=64, output_size=1):
        super(StockLSTM, self).__init__()
        self.lstm = nn.LSTM(input_size, hidden_size, batch_first=True)
        self.fc = nn.Linear(hidden_size, output_size)

    def forward(self, x):
        out, _ = self.lstm(x)
        return self.fc(out[:, -1, :])
# Cell 3: LSTM pipeline function

def train_lstm_model(ticker):
    df = yf.download(ticker, start="2015-01-01", end="2025-01-01")['Close'].dropna().to_frame()

    scaler = MinMaxScaler(feature_range=(-1, 1))
    scaled = scaler.fit_transform(df)

    X, y = [], []
    time_step = 30
    for i in range(len(scaled) - time_step):
        X.append(scaled[i:i+time_step])
        y.append(scaled[i+time_step])
    X = torch.tensor(X, dtype=torch.float32)
    y = torch.tensor(y, dtype=torch.float32)

    model = StockLSTM()
    loss_fn = nn.MSELoss()
    optimizer = torch.optim.Adam(model.parameters(), lr=0.001)

    for epoch in range(50):
        model.train()
        optimizer.zero_grad()
        out = model(X)
        loss = loss_fn(out, y)
        loss.backward()
        optimizer.step()

    model.eval()
    with torch.no_grad():
        x_input = torch.tensor(scaled[-time_step:], dtype=torch.float32).unsqueeze(0)
        forecast = model(x_input).numpy()
        return round(float(scaler.inverse_transform(forecast)[0][0]), 2)
# Cell 4: Run LSTM for 10 tickers

