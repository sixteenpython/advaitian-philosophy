VriddhiBhavishya.py (Standalone Version)
import numpy as np
import pandas as pd
import os
from datetime import datetime, timedelta
from keras.models import Sequential
from keras.layers import Dense, LSTM
from sklearn.preprocessing import MinMaxScaler
import yfinance as yf

FORECAST_MONTHS = [3, 6, 12, 24, 36, 48, 60]
PREDICTION_DIR = "predictions"

def fetch_price_data(ticker, start_date="2015-01-01", end_date=None):
    end_date = end_date or datetime.today().strftime('%Y-%m-%d')
    data = yf.download(ticker, start=start_date, end=end_date)
    return data['Close'].dropna()

def preprocess_data(prices, look_back=60):
    scaler = MinMaxScaler()
    scaled = scaler.fit_transform(prices.values.reshape(-1, 1))

    X, y = [], []
    for i in range(look_back, len(scaled)):
        X.append(scaled[i - look_back:i])
        y.append(scaled[i])
    return np.array(X), np.array(y), scaler

def build_model(input_shape):
    model = Sequential()
    model.add(LSTM(50, return_sequences=True, input_shape=input_shape))
    model.add(LSTM(50))
    model.add(Dense(1))
    model.compile(optimizer='adam', loss='mean_squared_error')
    return model

def forecast_future(model, recent_data, scaler, months=FORECAST_MONTHS):
    forecasted = {}
    current = recent_data.copy()

    for month in months:
        steps = month * 21  # approx trading days
        temp = current.copy()

        for _ in range(steps):
            input_batch = temp[-60:].reshape(1, 60, 1)
            next_val = model.predict(input_batch, verbose=0)[0][0]
            temp = np.append(temp, next_val)

        pred_val = scaler.inverse_transform(np.array([[temp[-1]]]))[0][0]
        forecasted[f"{month}m"] = round(pred_val, 2)

    return forecasted

def generate_forecast(ticker):
    prices = fetch_price_data(ticker)
    X, y, scaler = preprocess_data(prices)
    model = build_model(X.shape[1:])
    model.fit(X, y, epochs=10, batch_size=32, verbose=0)

    forecast = forecast_future(model, scaler.transform(prices.values[-60:].reshape(-1, 1)), scaler)
    forecast['Ticker'] = ticker
    forecast['BasePrice'] = round(prices.iloc[-1], 2)
    return forecast

def save_forecasts_to_csv(tickers):
    os.makedirs(PREDICTION_DIR, exist_ok=True)
    all_forecasts = []

    for ticker in tickers:
        print(f"Forecasting for: {ticker}")
        result = generate_forecast(ticker)
        all_forecasts.append(result)

    df = pd.DataFrame(all_forecasts)
    df.to_csv(os.path.join(PREDICTION_DIR, "predicted_prices.csv"), index=False)
    print("Forecasts saved.")

# Example usage
if __name__ == "__main__":
    tickers = ['HDFCBANK.NS', 'RELIANCE.NS', 'TCS.NS']
    save_forecasts_to_csv(tickers)
