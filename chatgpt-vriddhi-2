def calculate_hhs(row):
    # Normalize PEG: ideal ~1, lower is better until ~1.5
    peg_score = max(0, 10 - abs(row['PEG'] - 1) * 5)

    # P/B Score: ~1 is best, overvalued >3
    pb_score = max(0, 10 - (row['PB'] - 1) * 3)

    # P/E Score: ideal range 15-25
    if 15 <= row['PE'] <= 25:
        pe_score = 10
    else:
