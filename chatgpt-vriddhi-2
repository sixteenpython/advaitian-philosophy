# backtest_engine.py
import sqlite3
import pandas as pd
import yfinance as yf
from datetime import datetime, timedelta

DB_PATH = 'stock_fundamentals.db'
HORIZONS = {
    '3M': 3,
    '6M': 6,
    '12M': 12,
    '24M': 24,
    '36M': 36,
    '48M': 48,
    '60M': 60
}

def ensure_error_columns_exist():
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    for horizon in HORIZONS.keys():
        for col in [f'abs_error_{horizon.lower()}', f'pct_error_{horizon.lower()}']:
            try:
                cursor.execute(f"ALTER TABLE adjusted_predictions ADD COLUMN {col} REAL")
            except sqlite3.OperationalError:
                continue  # column already exists
    conn.commit()
    conn.close()

def fetch_actual_prices(tickers):
    data = yf.download(tickers, period="1d", interval="1d", progress=False)
    if len(tickers) == 1:
        return {tickers[0]: data['Close'].iloc[0]}
    else:
        return data['Close'].iloc[0].to_dict()

def update_errors():
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()

    for horizon_name, months_ago in HORIZONS.items():
        target_date = (datetime.today() - pd.DateOffset(months=months_ago)).strftime('%Y-%m-%d')

        # Fetch predictions made months_ago
        query = f"""
        SELECT ticker, adjusted_price
        FROM adjusted_predictions
        WHERE prediction_date = ?
        """
        predictions = pd.read_sql_query(query, conn, params=(target_date,))
        if predictions.empty:
            continue

        tickers = predictions['ticker'].tolist()
        actuals = fetch_actual_prices(tickers)
        predictions['actual_price'] = predictions['ticker'].map(actuals)
        predictions.dropna(subset=['actual_price'], inplace=True)

        predictions['abs_error'] = (predictions['actual_price'] - predictions['adjusted_price']).abs()
        predictions['pct_error'] = ((predictions['actual_price'] - predictions['adjusted_price']) / predictions['adjusted_price']) * 100

        for _, row in predictions.iterrows():
            cursor.execute(f"""
                UPDATE adjusted_predictions
                SET abs_error_{horizon_name.lower()} = ?, pct_error_{horizon_name.lower()} = ?
                WHERE ticker = ? AND prediction_date = ?
            """, (
                round(row['abs_error'], 2),
                round(row['pct_error'], 2),
                row['ticker'],
                target_date
            ))

    conn.commit()
    conn.close()
    print("[Backtest] Updated adjusted_predictions with latest error metrics.")

def run_backtest():
    print("[Backtest] Running backtest update...")
    ensure_error_columns_exist()
    update_errors()
    print("[Backtest] Completed successfully.")

if __name__ == "__main__":
    run_backtest()
