def compute_hhs(df):
    # Normalize features
    features = ['pe_ratio', 'pb_ratio', 'peg_ratio', 'dividend_yield']

    df = df.dropna(subset=features).copy()

    # Invert ratios where lower is better
    df['inv_pe'] = 1 / df['pe_ratio']
    df['inv_pb'] = 1 / df['pb_ratio']
    df['inv_peg'] = 1 / df['peg_ratio']

    scaled_features = ['inv_pe', 'inv_pb', 'inv_peg', 'dividend_yield']
    scaler = MinMaxScaler()
    df_scaled = pd.DataFrame(scaler.fit_transform(df[scaled_features]), columns=scaled_features)

    # Simple average HHS score
    df['health_score'] = df_scaled.mean(axis=1)

    return df[['ticker', 'health_score']]
