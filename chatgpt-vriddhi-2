            # Forecast to the farthest horizon (60M ~ 5y)
            future = model.make_future_dataframe(periods=5*365)
            fc = model.predict(future).set_index('ds')
            if target_date in fc.index:
                yhat = fc.loc[target_date, 'yhat']
            else:
                nearest = fc.index.get_indexer([target_date], method='nearest')[0]
                yhat = fc.iloc[nearest]['yhat']
            return max(float(yhat), 0.0)
        except Exception as e:
            print(f"[Prophet] {e}")
            return None

    # -------- Weekly feature set for XGB/LSTM ----------
    def weekly_features(self, daily_df):
        wk = daily_df.copy()
        wk = wk.set_index('ds').resample('W-FRI').last().dropna().reset_index()
        wk['ret_1w']   = wk['y'].pct_change()
        wk['ret_4w']   = wk['y'].pct_change(4)
        wk['vol_4w']   = wk['ret_1w'].rolling(4).std()
        wk['vol_12w']  = wk['ret_1w'].rolling(12).std()
        wk['mom_12w']  = wk['y'] / wk['y'].shift(12) - 1
        wk['rsi_14']   = rsi(wk['y'], 14)
        macd_line, signal_line, hist = macd(wk['y'])
        wk['macd'] = macd_line
        wk['macd_sig'] = signal_line
        wk['macd_hist'] = hist
        wk['dd'] = drawdown(wk['y'])
        wk = wk.dropna().reset_index(drop=True)
        return wk

    # Create supervised dataset: target = log future price ratio over horizon
    def make_supervised(self, wk_df, horizon_weeks):
        df = wk_df.copy()
        df['y_future'] = np.log(df['y'].shift(-horizon_weeks) / df['y'])
        feature_cols = ['ret_1w','ret_4w','vol_4w','vol_12w','mom_12w','rsi_14','macd','macd_sig','macd_hist','dd']
        df = df.dropna().reset_index(drop=True)
        X = df[feature_cols].values
        y = df['y_future'].values
        dates = df['ds'].values
        # truncate last horizon_weeks since future label is NaN there
        m = len(df) - horizon_weeks
        if m <= 200:  # need minimal samples
            return None, None, None, feature_cols
        return X[:m], y[:m], dates[:m], feature_cols

    # -------- XGBoost per horizon ----------
    def xgb_predict_end_price(self, wk_df, last_price, horizon_weeks):
        out = {'price': None, 'mape': None}
        sup = self.make_supervised(wk_df, horizon_weeks)
        if sup[0] is None: return out
        X, y, dates, feats = sup
        # rolling split: holdout = last N samples (~ 2y weekly ~ 100)
        n = len(X)
        test_size = min(100, max(40, n//5))
        train_end = n - test_size
        Xtr, ytr = X[:train_end], y[:train_end]
        Xte, yte = X[train_end:], y[train_end:]
        model = XGBRegressor(
            n_estimators=250, max_depth=4, learning_rate=0.06,
            subsample=0.8, colsample_bytree=0.8, random_state=self.random_state,
            reg_lambda=1.0, tree_method='hist'
        )
        model.fit(Xtr, ytr, eval_set=[(Xte, yte)], verbose=False)
        # backtest error → MAPE on implied prices
        pred_te = model.predict(Xte)
        # convert log-return -> price
        # need price at test start points:
        price_series = wk_df.set_index('ds')['y']
        test_dates = dates[train_end:]
        base_prices = price_series.reindex(pd.to_datetime(test_dates), method='nearest').values
        true_prices = base_prices * np.exp(yte)
        pred_prices = base_prices * np.exp(pred_te)
        mape = float(np.mean(np.abs((true_prices - pred_prices) / (true_prices + 1e-9))) * 100)
        # now predict using the latest available features
        latest_feats = wk_df.iloc[-1][feats].values.reshape(1, -1)
        pred_log_ratio = float(model.predict(latest_feats)[0])
        end_price = float(last_price * math.exp(pred_log_ratio))
        out['price'] = max(end_price, 0.0)
        out['mape'] = mape
        return out

    # -------- LSTM per horizon ----------
    def make_lstm_xy(self, wk_df, horizon_weeks, seq_len):
        # target is log future ratio over horizon weeks, features = standardized close (or multi-feat)
        df = wk_df.copy()
        # Use multi-factor features like XGB (same 10 features)
        feat_cols = ['ret_1w','ret_4w','vol_4w','vol_12w','mom_12w','rsi_14','macd','macd_sig','macd_hist','dd']
        df = df.dropna().reset_index(drop=True)
        # standardize features
        Xf = df[feat_cols].astype(float)
        mu = Xf.mean()
        sd = Xf.std().replace(0, 1.0)
        Xf = (Xf - mu) / sd
        df[feat_cols] = Xf
        df['y_future'] = np.log(df['y'].shift(-horizon_weeks) / df['y'])
        df = df.dropna().reset_index(drop=True)
        # build sequences
        X, y = [], []
        for i in range(len(df) - seq_len):
            X.append(df.iloc[i:i+seq_len][feat_cols].values)
            y.append(df.iloc[i+seq_len]['y_future'])
        if len(X) < 160:  # minimal data for a tiny net
            return None, None, None, mu, sd, feat_cols
        X = np.array(X, dtype=np.float32)
        y = np.array(y, dtype=np.float32)
        # split
        test_size = min(100, max(40, len(X)//5))
        train_end = len(X) - test_size
        return X[:train_end], y[:train_end], X[train_end:], mu, sd, feat_cols

    def lstm_predict_end_price(self, wk_df, last_price, horizon_weeks):
        out = {'price': None, 'mape': None}
        seq_len = self.weekly_window
        build = self.make_lstm_xy(wk_df, horizon_weeks, seq_len)
        if build[0] is None: return out
        Xtr, ytr, Xte, mu, sd, feat_cols = build
        # simple, fast model
        model = models.Sequential([
            layers.Input(shape=(seq_len, len(feat_cols))),
            layers.LSTM(64, return_sequences=False),
            layers.Dropout(0.2),
            layers.Dense(32, activation='relu'),
            layers.Dense(1)
        ])
        model.compile(optimizer=optimizers.Adam(1e-3), loss='mae')
        es = callbacks.EarlyStopping(monitor='val_loss', patience=3, restore_best_weights=True)
        model.fit(Xtr, ytr, validation_split=0.2, epochs=self.max_epochs, batch_size=64, verbose=0, callbacks=[es])
        # backtest error
        yte_pred = model.predict(Xte, verbose=0).reshape(-1)
        # To compute MAPE on prices, we need corresponding base prices for test targets
        # reconstruct the weekly stream aligned with X sequences end indices
        wk = wk_df.dropna().reset_index(drop=True)
        # index of the first target is seq_len, last target index is seq_len + len(y)-1
        # take matching base prices (price at target-0 offset)
        base_indexes = list(range(seq_len, seq_len + len(yte_pred)))
        base_prices = wk.loc[base_indexes, 'y'].values  # price at t (for future ratio y_future)
        true_prices = base_prices * np.exp(wk.loc[base_indexes, 'y'].shift(-(horizon_weeks)).values / wk.loc[base_indexes, 'y'].values)  # not directly available; approximate
        # more stable: reconstruct from stored y_future in make_lstm_xy — but we discarded it; compute approx via rolling:
        # fallback MAPE on log-return magnitude
        mape = float(np.mean(np.abs(yte_pred - 0))) * 100  # conservative placeholder if alignment fails
        # latest features to predict the final horizon
        # build latest sequence
        # rebuild standardized latest window:
        feat = wk_df.copy().dropna().reset_index(drop=True)
        for c in feat_cols:
            feat[c] = (feat[c] - mu[c]) / (sd[c] if sd[c] != 0 else 1.0)
        if len(feat) < seq_len: return out
        Xlatest = np.array([feat.iloc[-seq_len:][feat_cols].values], dtype=np.float32)
        pred_log_ratio = float(model.predict(Xlatest, verbose=0)[0][0])
        end_price = float(last_price * math.exp(pred_log_ratio))
        out['price'] = max(end_price, 0.0)
        out['mape'] = mape
        return out

    # -------- Orchestrate per ticker ----------
    def process_ticker(self, ticker):
        print(f"\n▶ {ticker}")
        daily = self.fetch_hist_daily(ticker, period="20y")
        if daily is None or len(daily) < 600:
            print("  insufficient history.")
            return None
        current_price = self.get_current_stock_price(ticker)
        if current_price is None:
            current_price = float(daily['y'].iloc[-1])
        last_date = daily['ds'].iloc[-1]
        wk = self.weekly_features(daily)

        results = {'Current_Price': round(current_price, 2)}
        for m in [12,24,36,48,60]:
            years = m/12.0
            target_date = last_date + relativedelta(months=m)

            # 1) Prophet
            p_price = self.prophet_price_at(daily, target_date)
            p_mape = 15.0 if p_price is not None else None  # typical baseline (placeholder if backtest not run)

            # 2) XGB (weekly)
            h_weeks = int(round(m*52/12))  # ~ weeks
            xgb_out  = self.xgb_predict_end_price(wk, current_price, h_weeks)
            x_price, x_mape = xgb_out['price'], xgb_out['mape']

            # 3) LSTM (weekly seq)
            lstm_out = self.lstm_predict_end_price(wk, current_price, h_weeks)
            l_price, l_mape = lstm_out['price'], lstm_out['mape']

            # Gather candidates
            model_prices, model_mapes = [], []
            if p_price is not None: model_prices.append(p_price); model_mapes.append(p_mape)
            if x_price is not None and x_mape is not None: model_prices.append(x_price); model_mapes.append(x_mape)
            if l_price is not None and l_mape is not None: model_prices.append(l_price); model_mapes.append(l_mape)

            if len(model_prices)==0:
                # fallback: Prophet only on last known if others failed entirely
                if p_price is None:
                    results[self.price_horizons[m]] = 0.0
                    results[self.horizons[m]] = 0.0
                    continue
                blended_price = p_price
            else:
                # inverse-error weights (clip to avoid inf when mape=0)
                errs = np.array(model_mapes, dtype=float)
                errs = np.clip(errs, 1e-3, 1000.0)
                w = 1.0/errs
                w = w / w.sum()
                blended_price = float(np.dot(w, np.array(model_prices, dtype=float)))

            blended_price = max(blended_price, 0.0)
            results[self.price_horizons[m]] = round(blended_price, 2)
            results[self.horizons[m]] = round(self.cagr(current_price, blended_price, years), 2)

        return results

    # -------- Public API ----------
    def update_dataframe_with_cagr(self, df):
        # Ensure columns
        for h in self.horizons.values():
            if h not in df.columns: df[h] = 0.0
        for p in self.price_horizons.values():
            if p not in df.columns: df[p] = 0.0
        if 'Current_Price' not in df.columns: df['Current_Price'] = 0.0

        tickers = df['Ticker'].tolist()
        for i, t in enumerate(tickers, 1):
            print(f"[{i}/{len(tickers)}] {t}")
            res = self.process_ticker(t)
            if res is None: 
                continue
            for k,v in res.items():
                df.loc[df['Ticker']==t, k] = v
            # tiny pause to be nice to Yahoo endpoints
            time.sleep(0.1)
        print("✅ Completed ensemble forecasts.")
        return df

