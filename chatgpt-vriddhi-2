 import pandas as pd import numpy as np from scipy.optimize import minimize import re  # =============================== # CONFIGURATION # =============================== FORECAST_MAP = {     12: "12M Forecast (% CAGR)",     18: "18M Forecast (% CAGR)",     24: "24M Forecast (% CAGR)",     36: "36M Forecast (% CAGR)",     48: "48M Forecast (% CAGR)",     60: "60M Forecast (% CAGR)", }  # =============================== # 1. STOCK SELECTION MODULE # =============================== def get_forecast_column(horizon_months):     return FORECAST_MAP.get(horizon_months, "60M Forecast (% CAGR)")  def stock_selector(df, expected_cagr, horizon_months):     forecast_col = get_forecast_column(horizon_months)      # Filter for quality     filtered = df[         (df["P/E"] > 0) & (df["P/E"] <= 40) &         (df["P/B"] > 0) & (df["P/B"] <= 10) &         (df["PEG"] > 0) & (df["PEG"] <= 2) &         (df["Momentum Score"] >= 70)     ].copy()      filtered = filtered.dropna(subset=[forecast_col, 'Volatility'])     filtered = filtered.sort_values(by=forecast_col, ascending=False)      selected_stocks = []     cumulative_cagr = 0     count = 0      for _, row in filtered.iterrows():         stock_cagr = row[forecast_col]         cumulative_cagr = ((cumulative_cagr * count) + stock_cagr) / (count + 1)         selected_stocks.append(row)         count += 1         if cumulative_cagr >= expected_cagr:             break      feasible = cumulative_cagr >= expected_cagr      if not feasible:         fallback_stocks = filtered.head(8)         fallback_cagr = fallback_stocks[forecast_col].mean()         return fallback_stocks.reset_index(drop=True), False, fallback_cagr     else:         selected_df = pd.DataFrame(selected_stocks).reset_index(drop=True)         return selected_df, True, cumulative_cagr  # =============================== # 2. OPTIMIZATION MODULE (MPT) # =============================== def optimize_portfolio(selected_df, horizon_months):     forecast_col = get_forecast_column(horizon_months)     returns = selected_df[forecast_col].values     risks = selected_df["Volatility"].values     cov_matrix = np.diag(risks ** 2)      def objective(weights):         port_return = np.dot(weights, returns)         port_vol = np.sqrt(np.dot(weights.T, np.dot(cov_matrix, weights)))         return -port_return / port_vol  # Maximize Sharpe      n = len(returns)     constraints = {'type': 'eq', 'fun': lambda x: np.sum(x) - 1}     bounds = [(0, 1)] * n     init_guess = np.ones(n) / n      result = minimize(objective, init_guess, method='SLSQP', bounds=bounds, constraints=constraints)      if result.success:         selected_df['Weight'] = result.x     else:         selected_df['Weight'] = 1.0 / n  # Fallback: equal weight      return selected_df  # =============================== # 3. FINAL PROJECTION & METRICS # =============================== def compute_projection(df, monthly_investment, horizon_months, horizon_cagr):     horizon_years = horizon_months / 12     total_investment = monthly_investment * horizon_months     cagr_rate = horizon_cagr / 100     future_value = total_investment * ((1 + cagr_rate) ** horizon_years)     return round(total_investment), round(future_value), round(future_value - total_investment)  # =============================== # 4. FINAL OUTPUT MODULE # =============================== def final_summary_output(feasible: bool,                          horizon_months: int,                          expected_cagr: float,                          achieved_cagr: float,                          projected_value: float,                          total_invested: float,                          best_horizon_60_cagr: float,                          max_possible_cagr_current_horizon: float):     """     Verbose English-based output summary with fallback recommendation if target is infeasible.     """      horizon_years = horizon_months / 12     gain = projected_value - total_invested      if feasible:         print("🎉 🎯 Your investment expectations can be met!\n")         print(f"In plain English: Based on your goal of investing ₹{int(total_invested):,} "               f"over {horizon_years:.1f} years with an expected CAGR of {expected_cagr:.2f}%, "               f"our model has found an optimal portfolio that achieves approximately "               f"{achieved_cagr:.2f}% CAGR.\n")         print(f"✨ This means your investment can grow to ₹{int(projected_value):,}, "               f"gaining ₹{int(gain):,} over the period.\n")         print("You're on track! 📈\n")     else:         print("⚠️ Unfortunately, your investment expectations cannot be fully met.\n")         print(f"In plain English: Based on your monthly investment and the selected horizon of "               f"{horizon_years:.1f} years, the best achievable CAGR is {max_possible_cagr_current_horizon:.2f}%, "               f"which falls short of your expected CAGR of {expected_cagr:.2f}%.\n")          print("🧠 However, here are our best recommendations:\n")         print(f"• 📊 Best CAGR achievable for {horizon_months} months: {max_possible_cagr_current_horizon:.2f}%")         print(f"• 🔁 If you can stretch to 60 months, the model can potentially achieve up to: "               f"{best_horizon_60_cagr:.2f}% CAGR.\n")          print("💡 You may want to reconsider your target CAGR or extend your investment horizon.\n")         print("Let us know if you want us to re-run the plan based on adjusted parameters.")  # =============================== # 5. WRAPPER FUNCTION # =============================== def run_vriddhi_backend(df, monthly_investment, expected_cagr, horizon_months):     selected_df, feasible, achieved_cagr = stock_selector(df, expected_cagr, horizon_months)     optimized_df = optimize_portfolio(selected_df, horizon_months)      optimized_df["Monthly Allocation (INR)"] = optimized_df["Weight"] * monthly_investment      total_invested, final_value, gain = compute_projection(         optimized_df, monthly_investment, horizon_months, achieved_cagr     )      # Fallback comparators     _, _, best_cagr_60 = stock_selector(df, expected_cagr, 60)      # Verbose summary     final_summary_output(         feasible=feasible,         horizon_months=horizon_months,         expected_cagr=expected_cagr,         achieved_cagr=achieved_cagr,         projected_value=final_value,         total_invested=total_invested,         best_horizon_60_cagr=best_cagr_60,         max_possible_cagr_current_horizon=achieved_cagr     )      return optimized_df[['Ticker', 'Weight', 'Monthly Allocation (INR)']], {         "Feasible": feasible,         "Expected CAGR": expected_cagr,         "Achieved CAGR": achieved_cagr,         "Final Value": final_value,         "Gain": gain     }   
