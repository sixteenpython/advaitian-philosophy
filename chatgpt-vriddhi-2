# vriddhi_bhavishya.py
import pandas as pd
import numpy as np
import joblib
from tensorflow.keras.models import load_model

class VriddhiBhavishya:
    def __init__(self, model_dir):
        self.model_dir = model_dir

    def load_model_and_scaler(self, ticker):
        model = load_model(f"{self.model_dir}/{ticker}_model.h5")
        scaler = joblib.load(f"{self.model_dir}/{ticker}_scaler.gz")
        return model, scaler

    def predict_future_prices(self, ticker, historical_data, n_months=60):
        model, scaler = self.load_model_and_scaler(ticker)
        data_scaled = scaler.transform(historical_data.reshape(-1, 1))
        input_seq = data_scaled[-60:].reshape(1, 60, 1)

        predictions = []
        for _ in range(n_months):
            next_val = model.predict(input_seq, verbose=0)[0][0]
            predictions.append(next_val)
            input_seq = np.roll(input_seq, -1)
            input_seq[0, -1, 0] = next_val

        predictions = scaler.inverse_transform(np.array(predictions).reshape(-1, 1)).flatten()
        return predictions
