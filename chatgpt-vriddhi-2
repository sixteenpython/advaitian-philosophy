import sqlite3

def compute_hhs_for_stock(pe, pb, peg, dividend_yield, sharpe_ratio, var):
    peg_score = max(0, 1 - (peg / 2))
    pe_score = max(0, 1 - (pe / 25))
    pb_score = max(0, 1 - (pb / 3))
    sharpe_score = max(0, 1 - abs(sharpe_ratio - 1))
    var_score = 1 - (var / 0.1) if var < 0.1 else 0

    weights = {'peg': 0.25, 'pe': 0.2, 'pb': 0.2, 'sharpe': 0.25, 'var': 0.1}
    hhs = (
        weights['peg'] * peg_score +
        weights['pe'] * pe_score +
        weights['pb'] * pb_score +
        weights['sharpe'] * sharpe_score +
        weights['var'] * var_score
    )
    return round(hhs, 2)

def compute_all_hhs():
    conn = sqlite3.connect('stock_fundamentals.db')
    cursor = conn.cursor()
    cursor.execute("SELECT * FROM fundamentals")
    stocks = cursor.fetchall()
    for stock in stocks:
        ticker, pe, pb, peg, dividend_yield = stock
        sharpe_ratio, var = 1.0, 0.05
        hhs = compute_hhs_for_stock(pe, pb, peg, dividend_yield, sharpe_ratio, var)
        cursor.execute("UPDATE fundamentals SET hhs = ? WHERE ticker = ?", (hhs, ticker))
    conn.commit()
    conn.close()
