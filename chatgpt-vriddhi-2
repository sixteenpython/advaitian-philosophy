           "AXISBANK.NS", "BAJFINANCE.NS", "ULTRACEMCO.NS", "SUNPHARMA.NS", "LT.NS"]

predictions = {}

for t in tickers:
    try:
        pred = train_lstm_model(t)
        predictions[t] = pred
        print(f"{t} → ₹{pred}")
    except Exception as e:
        print(f"{t} failed: {e}")
