# run_model.py — Linear Regression version for Vriddhi
import yfinance as yf
import pandas as pd
import sqlite3
from sklearn.linear_model import LinearRegression
import numpy as np
from datetime import datetime
import time

# Months to predict
TARGET_MONTHS = [3, 6, 12, 24, 36, 48, 60]

def fetch_monthly_close(ticker):
    try:
        df = yf.download(ticker, start="2015-01-01", interval="1mo", progress=False)
        df = df[["Close"]].dropna().reset_index()
        df["MonthIndex"] = np.arange(len(df))
        return df[["MonthIndex", "Close"]]
    except Exception as e:
        print(f"[Error] {ticker}: {e}")
        return None

def predict_prices(df):
    X = df[["MonthIndex"]].values
    y = df["Close"].values

    model = LinearRegression()
    model.fit(X, y)

    last_index = df["MonthIndex"].iloc[-1]
    future_indices = np.array([[last_index + m] for m in TARGET_MONTHS])
    future_prices = model.predict(future_indices)
    
    return {f"predicted_price_{m}m": round(float(p), 2) for m, p in zip(TARGET_MONTHS, future_prices)}

def update_predictions_to_db(tickers):
    conn = sqlite3.connect("stock_fundamentals.db")
    cursor = conn.cursor()

    # Ensure columns exist
    for m in TARGET_MONTHS:
        col = f"predicted_price_{m}m"
        try:
            cursor.execute(f"ALTER TABLE fundamentals ADD COLUMN {col} REAL")
        except:
            pass  # Column already exists

    for ticker in tickers:
        print(f"🔄 Predicting {ticker}")
        df = fetch_monthly_close(ticker)
        if df is None or df.empty:
            print(f"❌ Skipped {ticker} due to missing data")
            continue

        preds = predict_prices(df)

        # Build update query
        columns = ", ".join([f"{k} = ?" for k in preds])
        values = list(preds.values())
        cursor.execute(f"UPDATE fundamentals SET {columns} WHERE ticker = ?", (*values, ticker))

        time.sleep(0.3)  # be polite to yfinance

    conn.commit()
    conn.close()
    print("✅ All predictions updated.")

# Example usage:
if __name__ == "__main__":
    tickers = [
        "TCS.NS", "INFY.NS", "HDFCBANK.NS", "RELIANCE.NS", "ITC.NS",
        "ULTRACEMCO.NS", "BAJFINANCE.NS", "LT.NS", "SUNPHARMA.NS", "AXISBANK.NS"
    ]
