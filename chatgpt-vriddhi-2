🟩 Cell 2: Generate Valid Ticker List

def get_valid_tickers(limit=None):
    print("\n[Step 1] Generating validated ticker list...")
    url = "https://nsearchives.nseindia.com/content/equities/sec_list.csv"
    df = pd.read_csv(url)
    df = df[df['SERIES'] == 'EQ']
    symbols = df['SYMBOL'].dropna().unique().tolist()
    yf_tickers = [f"{s}.NS" for s in symbols]

    tickers = []
    for i, ticker in enumerate(yf_tickers):
        if limit and len(tickers) >= limit:
            break
        try:
            screener_url = f"https://www.screener.in/company/{ticker.replace('.NS','')}/"
            r = requests.get(screener_url, headers={'User-Agent': 'Mozilla/5.0'})
            df_price = yf.download(ticker, period="6mo", interval="1d", progress=False)
            if r.status_code == 200 and not df_price.empty:
                tickers.append(ticker)
                print(f"✔ {ticker}")
            else:
                print(f"✘ {ticker} - Failed")
        except:
            print(f"✘ {ticker} - Exception")
        time.sleep(0.2)
    print(f"\n✅ Final ticker count: {len(tickers)}")
    return tickers
🟩 Cell 3: Fetch Fundamentals and Store to Database

def fetch_and_store_fundamentals(tickers):
    print("\n[Step 2] Fetching fundamentals...")
    records = []

    for ticker in tickers:
        screener_url = f"https://www.screener.in/company/{ticker.replace('.NS','')}/"
        try:
            r = requests.get(screener_url, headers={'User-Agent': 'Mozilla/5.0'})
            soup = BeautifulSoup(r.text, 'html.parser')
            pe = float(soup.find(text='P/E').find_next().text.replace(',', ''))
            pb = float(soup.find(text='P/B').find_next().text.replace(',', ''))
            growth_tag = soup.find(text="Compounded Sales Growth")
            eps_growth = float(growth_tag.find_parent("table").find_all("tr")[1].find_all("td")[1].text.strip('%'))
            peg = round(pe / eps_growth, 2) if eps_growth != 0 else None
        except:
            pe, pb, peg = None, None, None

        try:
            df = yf.download(ticker, period="1y", interval="1d", progress=False)
            returns = df['Close'].pct_change().dropna()
            sharpe = round((returns.mean() - RISK_FREE_RATE_DAILY) / returns.std(), 2)
        except:
            sharpe = None

        records.append({
            "ticker": ticker,
            "pe_ratio": pe,
            "pb_ratio": pb,
            "peg_ratio": peg,
            "sharpe_ratio": sharpe
        })
        time.sleep(0.3)

    df_out = pd.DataFrame(records)
    conn = sqlite3.connect("stock_fundamentals.db")
    df_out.to_sql("fundamentals", conn, if_exists="replace", index=False)
    conn.close()
    print("✅ Fundamentals saved.")
🟩 Cell 4: Predict Future Prices Using Linear Regression

def run_predictions(tickers):
    print("\n[Step 3] Running price predictions...")
    conn = sqlite3.connect("stock_fundamentals.db")
    cursor = conn.cursor()

    for m in TARGET_MONTHS:
        try:
            cursor.execute(f"ALTER TABLE fundamentals ADD COLUMN predicted_price_{m}m REAL")
        except:
            pass

    for ticker in tickers:
        try:
            df = yf.download(ticker, start="2015-01-01", interval="1mo", progress=False)
            df = df[['Close']].dropna().reset_index()
            df['MonthIndex'] = np.arange(len(df))
            X = df[['MonthIndex']].values
            y = df['Close'].values
            model = LinearRegression()
            model.fit(X, y)
            last_index = df['MonthIndex'].iloc[-1]
            future_indices = np.array([[last_index + m] for m in TARGET_MONTHS])
            preds = model.predict(future_indices)
            pred_dict = {f"predicted_price_{m}m": round(float(p), 2) for m, p in zip(TARGET_MONTHS, preds)}
            columns = ", ".join([f"{k} = ?" for k in pred_dict])
            values = list(pred_dict.values())
            cursor.execute(f"UPDATE fundamentals SET {columns} WHERE ticker = ?", (*values, ticker))
        except Exception as e:
            print(f"Prediction error for {ticker}: {e}")
    conn.commit()
    conn.close()
    print("✅ Predictions updated.")
🟩 Cell 5: Compute HHS

def compute_hhs():
    print("\n[Step 4] Calculating HHS scores...")
    conn = sqlite3.connect("stock_fundamentals.db")
    df = pd.read_sql("SELECT * FROM fundamentals", conn)
    scores = []

    for _, row in df.iterrows():
        pe = row['pe_ratio'] or 0
        pb = row['pb_ratio'] or 0
        peg = row['peg_ratio'] or 0
        sharpe = row['sharpe_ratio'] or 0

        pe_score = max(0, 1 - pe / 25)
        pb_score = max(0, 1 - pb / 3)
        peg_score = max(0, 1 - peg / 2)
        sharpe_score = max(0, 1 - abs(sharpe - 1))

        hhs = 0.25 * pe_score + 0.25 * pb_score + 0.25 * peg_score + 0.25 * sharpe_score
        scores.append(round(hhs, 2))

    df['hhs'] = scores
    df.to_sql("fundamentals", conn, if_exists="replace", index=False)
    conn.close()
    print("✅ HHS saved.")
🟩 Cell 6: Apply Adjustments with HHS

def apply_hhs_adjustment():
    print("\n[Step 5] Adjusting predictions...")
    conn = sqlite3.connect("stock_fundamentals.db")
    df = pd.read_sql("SELECT * FROM fundamentals", conn)

    for m in TARGET_MONTHS:
        df[f"adjusted_price_{m}m"] = df[f"predicted_price_{m}m"] * (0.5 + df['hhs'])

    df.to_sql("fundamentals", conn, if_exists="replace", index=False)
    conn.close()
    print("✅ Adjusted predictions saved.")
