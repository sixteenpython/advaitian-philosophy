import yfinance as yf
import pandas as pd
import numpy as np
from sqlalchemy import create_engine
from datetime import datetime

# DB setup (SQLite for simplicity)
engine = create_engine("sqlite:///stock_fundamentals.db")

def compute_sharpe_ratio(returns):
    """Compute Sharpe Ratio (daily return basis)"""
    mean_daily_return = np.mean(returns)
    std_daily_return = np.std(returns)
    sharpe_ratio = mean_daily_return / std_daily_return if std_daily_return != 0 else np.nan
    return round(sharpe_ratio * np.sqrt(252), 4)  # Annualized

def compute_var(returns, confidence_level=0.05):
    """Compute historical Value at Risk (VaR)"""
    return round(np.percentile(returns, 100 * confidence_level), 4)

def fetch_fundamentals(ticker):
    try:
        t = yf.Ticker(ticker)
        info = t.info
        hist = t.history(period="1y")
        
        if hist.empty:
            raise ValueError("No price data found")

        # Compute returns
        hist['Daily Return'] = hist['Close'].pct_change().dropna()
        returns = hist['Daily Return'].dropna()

        data = {
            'ticker': ticker,
            'pe_ratio': info.get('trailingPE'),
            'pb_ratio': info.get('priceToBook'),
            'peg_ratio': info.get('pegRatio'),
            'sharpe_ratio': compute_sharpe_ratio(returns),
            'var_5pct': compute_var(returns),
            'last_updated': datetime.now().strftime('%Y-%m-%d')
        }
        return data

    except Exception as e:
        print(f"Error fetching data for {ticker}: {e}")
        return None
STEP 1C: INSERT/UPDATE INTO DATABASE

def update_database(tickers):
    updated_data = []
    for ticker in tickers:
        print(f"Fetching data for {ticker}")
        data = fetch_fundamentals(ticker)
        if data:
            updated_data.append(data)

    if updated_data:
        df = pd.DataFrame(updated_data)
        df.to_sql('fundamentals', con=engine, if_exists='replace', index=False)
        print("Database updated successfully!")
    else:
        print("No data to update.")
STEP 1D: RUN STEP 1

