import warnings, logging, os, time, math
warnings.filterwarnings('ignore')
logging.getLogger('prophet').setLevel(logging.ERROR)

import numpy as np
import pandas as pd
import yfinance as yf
from prophet import Prophet
from sklearn.preprocessing import MinMaxScaler
from sklearn.metrics import mean_absolute_percentage_error
from datetime import datetime
import xgboost as xgb
import tensorflow as tf
from tensorflow.keras import layers, callbacks, models

# -----------------------------
# Utility helpers
# -----------------------------
def _to_months(n_months):
    return int(n_months)

def _cagr(start_price, end_price, years):
    if start_price is None or end_price is None:
        return 0.0
    if start_price <= 0 or end_price <= 0 or years <= 0:
        return 0.0
    return ( (end_price / start_price) ** (1.0 / years) - 1.0 ) * 100.0

def _safe_mape(y_true, y_pred):
    try:
        return mean_absolute_percentage_error(np.asarray(y_true), np.asarray(y_pred))
    except:
        return 1.0

def _progress(i, n, prefix="Progress"):
    print(f"{prefix}: {i}/{n}")

# -----------------------------
# Core Predictor
# -----------------------------
class StockCAGRPredictor:
    def __init__(self, 
                 horizons=(12,24,36,48,60),
                 lstm_seq=60,            # 60 months history as input sequence
                 lstm_epochs=50,         # EarlyStopping cuts it earlier in practice
                 lstm_patience=6,
                 xgb_rounds=120,
                 max_lookback_years=20):
        
        self.horizons = list(horizons)
        self.horizon_cols = {m: f"Forecast_{m}M" for m in self.horizons}
        self.price_cols   = {m: f"Expected_Price_{m}M" for m in self.horizons}
        self.max_lookback_years = max_lookback_years

        # LSTM config
        self.lstm_seq = lstm_seq
        self.lstm_epochs = lstm_epochs
        self.lstm_patience = lstm_patience

        # XGBoost config
        self.xgb_rounds = xgb_rounds

    # -----------------------------
    # Data fetch
    # -----------------------------
    def _get_current_price(self, ticker):
        try:
            t = yf.Ticker(f"{ticker}.NS")
            # Try fast info
            try:
                info = t.fast_info
                p = info.get('last_price', None)
                if p and p > 0:
                    return round(float(p), 2)
            except:
                pass

            # Fallback: last close from 5d
            hist = t.history(period="5d")
            if not hist.empty:
                return round(float(hist['Close'].iloc[-1]), 2)
        except Exception as e:
            print(f"[WARN] Current price fetch fail {ticker}: {e}")
        return None

    def _fetch_monthly_history(self, ticker):
        try:
            df = yf.download(f"{ticker}.NS", period=f"{self.max_lookback_years}y", interval="1mo", auto_adjust=False, progress=False)
            if df is None or df.empty:
                return None
            df = df.reset_index()
            # yfinance monthly index column name can be 'Date' or 'Datetime'
            date_col = 'Date' if 'Date' in df.columns else 'Datetime'
            df = df[[date_col, 'Close']].dropna()
            df.rename(columns={date_col: 'ds', 'Close': 'y'}, inplace=True)
            df['ds'] = pd.to_datetime(df['ds'])
            # Ensure one row per month (resample end-of-month if needed)
            df = df.set_index('ds').resample('M').last().dropna().reset_index()
            return df
        except Exception as e:
            print(f"[ERROR] Fetch monthly failed {ticker}: {e}")
            return None

    # -----------------------------
    # Prophet model (monthly)
    # -----------------------------
    def _fit_prophet(self, df_monthly):
        m = Prophet(
            daily_seasonality=False,
            weekly_seasonality=False,
            yearly_seasonality=True,
            changepoint_prior_scale=0.2,
            seasonality_prior_scale=10,
            interval_width=0.8
        )
        train = df_monthly[['ds','y']].copy()
        m.fit(train)
        return m

    def _forecast_prophet(self, model, n_months):
        future = model.make_future_dataframe(periods=n_months, freq='M')
        fc = model.predict(future)
        # return the last n_months predictions mapped by horizon month
        preds = {}
        # The last row is full horizon; we need exact months: 12,24,36,48,60
        # Pick by index relative to the end
        total = len(fc)
        for m in self.horizons:
            idx = total - ( (max(self.horizons) - m) + 1 )
            idx = min(max(0, idx), total-1)
            preds[m] = max(float(fc['yhat'].iloc[idx]), 0.0)
        return preds

    # -----------------------------
    # LSTM model (recursive monthly)
    # -----------------------------
    def _fit_lstm_and_forecast(self, df_monthly, n_months):
        # Scale
        series = df_monthly['y'].values.reshape(-1,1).astype('float32')
        scaler = MinMaxScaler()
        scaled = scaler.fit_transform(series)

        seq_len = min(self.lstm_seq, len(scaled)-1)
        if seq_len < 24:  # need enough history
            # Fallback: naive hold-last
            last_val = float(series[-1,0])
            return {m: last_val for m in self.horizons}

        X, y = [], []
        for i in range(seq_len, len(scaled)):
            X.append(scaled[i-seq_len:i, 0])
            y.append(scaled[i, 0])
        X = np.array(X)
        y = np.array(y)
        X = X.reshape((X.shape[0], X.shape[1], 1))

        # Build LSTM
        model = models.Sequential([
            layers.Input(shape=(X.shape[1], 1)),
            layers.LSTM(64, return_sequences=False),
            layers.Dense(32, activation='relu'),
            layers.Dense(1)
        ])
        model.compile(optimizer='adam', loss='mse')

        es = callbacks.EarlyStopping(monitor='val_loss', patience=self.lstm_patience, restore_best_weights=True)
        model.fit(X, y, validation_split=0.2, epochs=self.lstm_epochs, batch_size=32, verbose=0, callbacks=[es])

        # Recursive monthly forecasting to 60M
        future_scaled = scaled.copy()
        preds_map = {}
        need_months = max(self.horizons)
        buffer = list(future_scaled[:,0])

        for step in range(need_months):
            last_seq = np.array(buffer[-seq_len:]).reshape(1, seq_len, 1)
            next_scaled = float(model.predict(last_seq, verbose=0)[0,0])
            buffer.append(next_scaled)

            # If this step completes a target horizon, store it
            month_ahead = step + 1
            if month_ahead in self.horizons:
                val = scaler.inverse_transform(np.array(next_scaled).reshape(-1,1))[0,0]
                preds_map[month_ahead] = max(float(val), 0.0)

        # Ensure all horizons exist (fallback to last known)
        last_price = float(df_monthly['y'].iloc[-1])
        for m in self.horizons:
            preds_map.setdefault(m, last_price)
        return preds_map

    # -----------------------------
    # XGBoost model (lag features + recursive)
    # -----------------------------
    def _build_xgb_features(self, y_series, max_lag=12):
        df = pd.DataFrame({'y': y_series})
        # Lags
        for k in range(1, max_lag+1):
            df[f'lag_{k}'] = df['y'].shift(k)
        # Rolling stats
        df['roll_mean_3'] = df['y'].rolling(3).mean()
        df['roll_std_3']  = df['y'].rolling(3).std()
        df['roll_mean_6'] = df['y'].rolling(6).mean()
        df['roll_std_6']  = df['y'].rolling(6).std()
        df['roll_mean_12'] = df['y'].rolling(12).mean()
        df['roll_std_12']  = df['y'].rolling(12).std()
        df = df.dropna().reset_index(drop=True)
        return df

    def _fit_xgb_and_forecast(self, df_monthly, n_months):
        y = df_monthly['y'].values
        if len(y) < 36:
            # Too short, fallback naive
            last_val = float(y[-1])
            return {m: last_val for m in self.horizons}

        feat = self._build_xgb_features(y, max_lag=12)
        y_train = feat['y'].values
        X_train = feat.drop(columns=['y']).values

        dtrain = xgb.DMatrix(X_train, label=y_train)
        params = {
            'objective': 'reg:squarederror',
            'eval_metric': 'rmse',
            'eta': 0.08,
            'max_depth': 4,
            'subsample': 0.8,
            'colsample_bytree': 0.8,
            'seed': 42
        }
        model = xgb.train(params, dtrain, num_boost_round=self.xgb_rounds, verbose_eval=False)

        # Recursive monthly forecasts
        hist = list(y.copy())
        preds_map = {}
        for step in range(max(self.horizons)):
            # build last feature row from hist
            tmp = pd.DataFrame({'y': hist})
            tmp_feat = self._build_xgb_features(np.array(hist), max_lag=12)
            # last row features:
            X_last = tmp_feat.drop(columns=['y']).iloc[[-1]].values
            dtest = xgb.DMatrix(X_last)
            next_y = float(model.predict(dtest)[0])
            hist.append(next_y)

            month_ahead = step + 1
            if month_ahead in self.horizons:
                preds_map[month_ahead] = max(next_y, 0.0)

        # Ensure all horizons exist
        last_price = float(y[-1])
        for m in self.horizons:
            preds_map.setdefault(m, last_price)
        return preds_map

    # -----------------------------
    # Per-ticker validation weights
    # -----------------------------
    def _blend_weights_via_validation(self, df_monthly):
        """
        Compute model weights from recent 5y validation by comparing 1..12 month-ahead forecasts.
        We approximate per-model error and convert to weights ∝ 1/MAPE.
        """
        # Need at least ~ 7-8 years to have a solid 5y val after train
        if len(df_monthly) < 96:
            # Short series → equal weights
            return {'prophet': 1/3, 'lstm': 1/3, 'xgb': 1/3}

        # Split train/val at last 60 months (5y)
        split_idx = max(12, len(df_monthly) - 60)
        train_df = df_monthly.iloc[:split_idx].copy()
        val_df   = df_monthly.iloc[split_idx:].copy()   # 60 rows monthly

        # Fit models on train
        try:
            p_model = self._fit_prophet(train_df)
            p_preds = self._forecast_prophet(p_model, n_months=len(val_df))
        except:
            p_model, p_preds = None, {}

        try:
            l_preds = self._fit_lstm_and_forecast(train_df, n_months=len(val_df))
        except:
            l_preds = {}

        try:
            x_preds = self._fit_xgb_and_forecast(train_df, n_months=len(val_df))
        except:
            x_preds = {}

        # Build comparable arrays: step-ahead 1..min(12, len(val))
        steps = min(12, len(val_df))
        true_vals = val_df['y'].iloc[:steps].values

        def seq_from_map(pred_map, steps):
            # pred_map is keyed by 1..N horizon; we want 1..steps
            return np.array([pred_map.get(i, np.nan) for i in range(1, steps+1)], dtype=float)

        p_seq = seq_from_map(p_preds, steps) if p_preds else np.full(steps, np.nan)
        l_seq = seq_from_map(l_preds, steps) if l_preds else np.full(steps, np.nan)
        x_seq = seq_from_map(x_preds, steps) if x_preds else np.full(steps, np.nan)

        def mape_clean(y, yhat):
            mask = (~np.isnan(yhat)) & (~np.isnan(y)) & (y > 0)
            if mask.sum() < 3:
                return 0.25  # default error
            return _safe_mape(y[mask], yhat[mask])

        err_p = mape_clean(true_vals, p_seq)
        err_l = mape_clean(true_vals, l_seq)
        err_x = mape_clean(true_vals, x_seq)

        # Convert to weights: w_i ∝ 1 / (err_i + eps)
        eps = 1e-6
        inv = np.array([1.0/(err_p+eps), 1.0/(err_l+eps), 1.0/(err_x+eps)], dtype=float)
        # Floor to avoid zeroing any model:
        floor = 0.10
        w = inv / inv.sum()
        w = np.maximum(w, floor)
        w = w / w.sum()
        return {'prophet': float(w[0]), 'lstm': float(w[1]), 'xgb': float(w[2])}

    # -----------------------------
    # Full per-ticker processing
    # -----------------------------
    def process_ticker(self, ticker):
        print(f"\n=== {ticker} ===")

        hist = self._fetch_monthly_history(ticker)
        if hist is None or hist.empty or len(hist) < 36:
            print("Insufficient history, skipping.")
            return None

        current_price = self._get_current_price(ticker)
        if current_price is None:
            current_price = float(hist['y'].iloc[-1])

        # Fit models on full history
        # Prophet
        try:
            p_model = self._fit_prophet(hist)
            p_fc = self._forecast_prophet(p_model, n_months=max(self.horizons))
        except Exception as e:
            print(f"[WARN] Prophet failed {ticker}: {e}")
            p_fc = {m: float(hist['y'].iloc[-1]) for m in self.horizons}

        # LSTM
        try:
            l_fc = self._fit_lstm_and_forecast(hist, n_months=max(self.horizons))
        except Exception as e:
            print(f"[WARN] LSTM failed {ticker}: {e}")
            l_fc = {m: float(hist['y'].iloc[-1]) for m in self.horizons}

        # XGB
        try:
            x_fc = self._fit_xgb_and_forecast(hist, n_months=max(self.horizons))
        except Exception as e:
            print(f"[WARN] XGB failed {ticker}: {e}")
            x_fc = {m: float(hist['y'].iloc[-1]) for m in self.horizons}

        # Per-ticker weights via recent validation
        try:
            w = self._blend_weights_via_validation(hist)
        except Exception as e:
            print(f"[WARN] Weighting failed {ticker}: {e}")
            w = {'prophet': 1/3, 'lstm': 1/3, 'xgb': 1/3}

        # Blend predictions
        out = {'Ticker': ticker, 'Current_Price': round(float(current_price), 2)}
        for m in self.horizons:
            blended = (
                w['prophet'] * p_fc.get(m, current_price) +
                w['lstm']   * l_fc.get(m, current_price) +
                w['xgb']    * x_fc.get(m, current_price)
            )
            blended = max(float(blended), 0.0)
            out[self.price_cols[m]] = round(blended, 2)
            years = m/12.0
            out[self.horizon_cols[m]] = round(_cagr(current_price, blended, years), 2)

        return out

    # -----------------------------
    # Public API
    # -----------------------------
    def update_dataframe_with_cagr(self, df):
        assert 'Ticker' in df.columns, "Input df must have a 'Ticker' column."

        # Ensure output columns exist
        for m in self.horizons:
            pc = self.price_cols[m]
            hc = self.horizon_cols[m]
            if pc not in df.columns: df[pc] = 0.0
            if hc not in df.columns: df[hc] = 0.0
        if 'Current_Price' not in df.columns:
            df['Current_Price'] = 0.0

        tickers = df['Ticker'].tolist()
        n = len(tickers)
        for i, t in enumerate(tickers, start=1):
            _progress(i, n, prefix="Tickers")
            try:
                res = self.process_ticker(t)
                if res is None:
                    continue
                df.loc[df['Ticker']==t, 'Current_Price'] = res['Current_Price']
                for m in self.horizons:
                    df.loc[df['Ticker']==t, self.price_cols[m]]   = res[self.price_cols[m]]
                    df.loc[df['Ticker']==t, self.horizon_cols[m]] = res[self.horizon_cols[m]]
            except Exception as e:
                print(f"[ERROR] {t}: {e}")
            time.sleep(0.05)  # polite pacing

        # Order columns for display
        ordered_cols = (['Ticker','Current_Price'] +
                        [self.price_cols[m] for m in self.horizons] +
                        [self.horizon_cols[m] for m in self.horizons])
        # keep any extra columns at the end
        extra = [c for c in df.columns if c not in ordered_cols]
        df = df[ordered_cols + extra]
        return df

# -----------------------------
# Runner
# -----------------------------
def main(input_df):
    predictor = StockCAGRPredictor()
    print("Starting ensemble forecast (Prophet + LSTM + XGBoost) for 12/24/36/48/60M...")
    updated_df = predictor.update_dataframe_with_cagr(input_df.copy())

    # Pretty print a compact table with the key columns
    display_cols = ['Ticker','Current_Price',
                    'Expected_Price_12M','Expected_Price_24M','Expected_Price_36M','Expected_Price_48M','Expected_Price_60M',
                    'Forecast_12M','Forecast_24M','Forecast_36M','Forecast_48M','Forecast_60M']
    available = [c for c in display_cols if c in updated_df.columns]
    print("\n=== Results ===")
    print(updated_df[available].to_string(index=False))
    return updated_df

def run_cagr_prediction(df):
    return main(df)
