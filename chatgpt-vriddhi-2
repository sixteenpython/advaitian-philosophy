class StockCAGRPredictor:
    def __init__(self):
        self.horizons = {
            12: 'Forecast_12M', 
            24: 'Forecast_24M',
            36: 'Forecast_36M',
            48: 'Forecast_48M',
            60: 'Forecast_60M'
        }
        
        # Corresponding price columns
        self.price_horizons = {
            12: 'Expected_Price_12M', 
            24: 'Expected_Price_24M',
            36: 'Expected_Price_36M',
            48: 'Expected_Price_48M',
            60: 'Expected_Price_60M'
        }
        
    def get_current_stock_price(self, ticker):
        """
        Get current/latest stock price from Yahoo Finance
        """
        try:
            stock_symbol = f"{ticker}.NS"
            stock = yf.Ticker(stock_symbol)
            
            # Try to get current price from info
            try:
                info = stock.info
                current_price = info.get('currentPrice') or info.get('regularMarketPrice') or info.get('previousClose')
                if current_price and current_price > 0:
                    return round(current_price, 2)
            except:
                pass
            
            # Fallback: Get latest price from recent history
            hist = stock.history(period="5d")
            if not hist.empty:
                current_price = hist['Close'].iloc[-1]
                return round(current_price, 2)
            
            return None
            
        except Exception as e:
            print(f"Error fetching current price for {ticker}: {str(e)}")
            return None

    def fetch_stock_data(self, ticker, period="20y"):
        """
        Fetch historical stock data from Yahoo Finance
        """
        try:
            # Add .NS suffix for NSE stocks
            stock_symbol = f"{ticker}.NS"
            stock = yf.Ticker(stock_symbol)
            
            # Get historical data
            hist = stock.history(period=period)
            
            if hist.empty:
                print(f"No data found for {ticker}")
                return None, None
                
            # Get current price
            current_price = self.get_current_stock_price(ticker)
            if current_price is None:
                current_price = round(hist['Close'].iloc[-1], 2)
            
            print(f"{ticker}: Current Price = ₹{current_price}")
            
            # Prepare data for Prophet (requires 'ds' and 'y' columns)
            data = hist.reset_index()
            data = data[['Date', 'Close']].copy()
            data.columns = ['ds', 'y']
            
            # Remove timezone from datetime column for Prophet compatibility
            if data['ds'].dt.tz is not None:
                data['ds'] = data['ds'].dt.tz_localize(None)
            
            # Ensure datetime format
            data['ds'] = pd.to_datetime(data['ds'])
            
            return data, current_price
            
        except Exception as e:
            print(f"Error fetching data for {ticker}: {str(e)}")
            return None, None
    
    def calculate_cagr(self, start_price, end_price, years):
        """
        Calculate Compound Annual Growth Rate
        """
